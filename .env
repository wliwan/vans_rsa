# ═══════════════════════════════════════════════
# Vance Road Scanner Assistant 环境变量
#
# 复制为 .env 后按需修改:
#   copy .env.example .env
# ═══════════════════════════════════════════════

# ── 服务端口 ──
# 宿主机访问端口（默认 1110）
APP_PORT=1110

# ── Docker 镜像源（国内用户修改此项避免 429 限流） ──
# 可选镜像源：
#   docker.m.daocloud.io     （daocloud 镜像，推荐）
#   docker.1ms.run           （备用）
#   留空使用 docker.io        （直连官方 Hub，科学上网环境推荐）
NODE_IMAGE=docker.m.daocloud.io/library/node:22-alpine
PYTHON_IMAGE=docker.m.daocloud.io/library/python:3.11-slim-bullseye
